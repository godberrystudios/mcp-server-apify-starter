{
  "name": "mcp-server-apify-starter",
  "version": "0.1.0",
  "description": "Production-ready starter for building a pay-per-use MCP server on the Apify platform. Ships with Streamable HTTP transport, Apify Actor Standby mode, and per-event billing wired up.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "inspect": "npx @modelcontextprotocol/inspector http://localhost:4321/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apify",
    "anthropic",
    "claude",
    "starter",
    "boilerplate",
    "ai-agents"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "apify": "^3.3.2",
    "express": "^4.21.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Godberry Studios <hello@godberrystudios.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/godberrystudios/mcp-server-apify-starter.git"
  }
}
